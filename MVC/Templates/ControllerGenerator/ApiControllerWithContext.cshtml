@inherits Microsoft.VisualStudio.Web.CodeGeneration.Templating.RazorTemplateBase
@{
if (@Model.NullableEnabled)
{
@:#nullable disable

}
}
using Microsoft.AspNetCore.Mvc;
using MediatR;
using N4C.App;
using N4C.App.Features;
@{
    foreach (var namespaceName in Model.RequiredNamespaces)
    {
@:using @(namespaceName.Remove(namespaceName.LastIndexOf('.')) + ".Features." + Model.ControllerRootName);
    }
}

// Generated from N4C Template.

namespace @Model.ControllerNamespace
{
@{
    string routePrefix = Model.ControllerRootName + "ApiController";
    var entitySetName = Model.ModelMetadata.EntitySetName;
    var primaryKeyName = Model.ModelMetadata.PrimaryKeys[0].PropertyName;
    var primaryKeyShortTypeName = Model.ModelMetadata.PrimaryKeys[0].ShortTypeName;
    var primaryKeyType = Model.ModelMetadata.PrimaryKeys[0].TypeName;
    var primaryKeyIsAutoGenerated = Model.ModelMetadata.PrimaryKeys[0].IsAutoGenerated;

    var queryRequestType = @Model.ModelTypeName + "QueryRequest";
    var commandRequestType = @Model.ModelTypeName + "CommandRequest";
}
    [Route("[controller]")]
    [ApiController]
    //[Authorize(AuthenticationSchemes = JwtBearerDefaults.AuthenticationScheme)]
    public class @(Model.ControllerRootName + "ApiController") : ControllerBase
    {
        // Mediator injection:
        private readonly IMediator _mediator;

        public @(Model.ControllerRootName + "ApiController (IMediator mediator)")
        {
            _mediator = mediator;
        }

        ObjectResult ActionResult(Result result)
        {
            return StatusCode((int)result.HttpStatusCode, result);
        }

        // GET: @routePrefix
        [HttpGet]
        public async Task<IActionResult> Get()
        {
            // Get collection logic:
            var result = await _mediator.Send(new @(queryRequestType + "()"));

            return ActionResult(result);
        }

        // GET: @routePrefix/5
        [HttpGet("{id}")]
        public async Task<IActionResult> Get(@primaryKeyShortTypeName id)
        {
            // Get item logic:
            var result = await _mediator.Send(new @(queryRequestType + "() { Id = id }"));
            
            return ActionResult(result);
        }

		// POST: @routePrefix
        [HttpPost]
        public async Task<IActionResult> Post(@commandRequestType request)
        {
            request.Command = Commands.Create;
            request.ModelState = ModelState;

            // Insert item logic:
            var result = await _mediator.Send(request);

            return ActionResult(result);
        }

        // PUT: @routePrefix
        [HttpPut]
        public async Task<IActionResult> Put(@commandRequestType request)
        {
            request.Command = Commands.Update;
            request.ModelState = ModelState;
            
            // Update item logic:
            var result = await _mediator.Send(request);

            return ActionResult(result);
        }

        // DELETE: @routePrefix/5
        [HttpDelete("{id}")]
        public async Task<IActionResult> Delete(@primaryKeyShortTypeName id)
        {
            // Delete item logic:
            var result = await _mediator.Send(new @(commandRequestType + "() { Command = Commands.Delete, Id = id }"));

            return ActionResult(result);
        }
	}
}