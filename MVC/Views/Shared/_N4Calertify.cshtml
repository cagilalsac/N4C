@using N4C.App

@* https://alertifyjs.com/ *@

<link href="~/lib/AlertifyJS/css/alertify.min.css" rel="stylesheet" />
<link href="~/lib/AlertifyJS/css/themes/default.min.css" rel="stylesheet" />
<script src="~/lib/AlertifyJS/alertify.min.js"></script>

@{
    var view = (View?)ViewBag.View;
    var culture = view is null ? Cultures.TR : view.Culture;
    var title = culture == Cultures.TR ? "Uyarı!" : "Warning!";
    var message = culture == Cultures.TR ? "Bu kaydı silmek istediğinize emin misiniz?" : "Are you sure you want to delete this record?";
    var yes = culture == Cultures.TR ? "Evet" : "Yes";
    var no = culture == Cultures.TR ? "Hayır" : "No";
    var deleteMvcAction = (int)MvcActions.DeleteGet;
}

<script>
    function deleteRecord(id, deleteMvcAction = 0) {
        var deleteAction = deleteMvcAction == @deleteMvcAction ? 'Index?Request.Id=' + id + '&MvcAction=@deleteMvcAction' : 'DeleteByAlertify/' + id;
        alertify.confirm('@title',
            '@message',
            function () { // OK
            @if (ViewContext.RouteData.Values["Area"] is not null)
            {
                @:window.location.href = '/@ViewContext.RouteData.Values["Area"]/@ViewContext.RouteData.Values["Controller"].ToString()/' + deleteAction;
            }
            else
            {
                @:window.location.href = '/@ViewContext.RouteData.Values["Controller"].ToString()/' + deleteAction;
            }
            },
            function () { // Cancel
            @if (ViewContext.RouteData.Values["Area"] is not null)
            {
                @:window.location.href = '/@ViewContext.RouteData.Values["Area"]/@ViewContext.RouteData.Values["Controller"].ToString()/Index?session=true';
            }
            else
            {
                @:window.location.href = '/@ViewContext.RouteData.Values["Controller"].ToString()/Index?session=true';
            }
            }
        ).set('labels', { ok: '@yes', cancel: '@no' });
    }
</script>